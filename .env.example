# Copie ce fichier en ".env" (à la racine du projet), puis remplis tes vraies valeurs.
# Le fichier ".env" ne doit JAMAIS être commité sur Git (il est déjà dans .gitignore) —
# c'est ce fichier .env.example, sans valeurs réelles, qui est versionné à sa place.

# Nom de ta base de données PostgreSQL
DB_NAME=

# Utilisateur PostgreSQL
DB_USER=

# Mot de passe de cet utilisateur PostgreSQL
DB_PASS=

# Clé secrète utilisée pour signer/vérifier les tokens JWT.
# Génère-en une vraie avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
